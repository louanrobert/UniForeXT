    <!-- http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#hasTimestamp -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#hasTimestamp">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#Independent_entity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTimeStamp"/>
        <rdfs:comment xml:lang="en">Stores the timestamp associated with an entity or event.</rdfs:comment>
        <rdfs:label xml:lang="en">hasTimestamp</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#hasValue -->

