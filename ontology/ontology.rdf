    <!-- http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#hasID -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#hasID">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#Detection"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#unsignedLong"/>
        <rdfs:comment xml:lang="en">Stores the identifier of a detection record.</rdfs:comment>
        <rdfs:label xml:lang="en">hasID</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#hasIP -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#hasIP">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#Computer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Stores the IP address associated with a computer.</rdfs:comment>
        <rdfs:label xml:lang="en">hasIP</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#hasLevel -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#hasLevel">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#Detection"/>
        <rdfs:range>
            <rdfs:Datatype>
                <owl:oneOf>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                        <rdf:first>High</rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                <rdf:first>Info</rdf:first>
                                <rdf:rest>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                        <rdf:first>Low</rdf:first>
                                        <rdf:rest>
                                            <rdf:Description>
                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                <rdf:first>Medium</rdf:first>
                                                <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                                            </rdf:Description>
                                        </rdf:rest>
                                    </rdf:Description>
                                </rdf:rest>
                            </rdf:Description>
                        </rdf:rest>
                    </rdf:Description>
                </owl:oneOf>
            </rdfs:Datatype>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Stores the severity level associated with a detection.</rdfs:comment>
        <rdfs:label xml:lang="en">hasLevel</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#hasName -->

