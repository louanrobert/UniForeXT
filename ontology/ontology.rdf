        <owl:inverseOf rdf:resource="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#isUserOf"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#Independent_entity"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#User"/>
        <rdfs:comment xml:lang="en">Relates an entity to the user associated with it.</rdfs:comment>
        <rdfs:label xml:lang="en">hasUser</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#isAttackTacticOf -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#isAttackTacticOf">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#AttackTactic"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#Domain_entity"/>
        <rdfs:comment xml:lang="en">Inverse of hasAttackTactic; associates an ATT&amp;CK tactic to entities using it.</rdfs:comment>
        <rdfs:label xml:lang="en">isAttackTacticOf</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#isAttackTechniqueOf -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#isAttackTechniqueOf">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#AttackTechnique"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#Domain_entity"/>
        <rdfs:comment xml:lang="en">Inverse of hasAttackTechnique; associates an ATT&amp;CK technique to entities using it.</rdfs:comment>
        <rdfs:label xml:lang="en">isAttackTechniqueOf</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#isCommandOf -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#isCommandOf">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#Command"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#Independent_entity"/>
        <rdfs:comment xml:lang="en">Inverse of hasCommand; associates a command to entities that used it.</rdfs:comment>
        <rdfs:label xml:lang="en">isCommandOf</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#isComputerOf -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#isComputerOf">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#Computer"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#Independent_entity"/>
        <rdfs:comment xml:lang="en">Inverse of hasComputer; associates a computer to entities observed on it.</rdfs:comment>
        <rdfs:label xml:lang="en">isComputerOf</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#isDetectionOf -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#isDetectionOf">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#Detection"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#Event"/>
        <rdfs:comment xml:lang="en">Inverse of hasDetection; associates a detection to the events it identified.</rdfs:comment>
        <rdfs:label xml:lang="en">isDetectionOf</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#isLogFileOf -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#isLogFileOf">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#LogFile"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#Independent_entity"/>
        <rdfs:comment xml:lang="en">Inverse of hasLogFile; associates a log file to entities that reference it.</rdfs:comment>
        <rdfs:label xml:lang="en">isLogFileOf</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#isLogonEventOf -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#isLogonEventOf">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#LogonEvent"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#Session"/>
        <rdfs:comment xml:lang="en">Inverse of hasLogonEvent; associates a logon event to the session it created.</rdfs:comment>
        <rdfs:label xml:lang="en">isLogonEventOf</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#isLogonTypeOf -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#isLogonTypeOf">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#LogonType"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#LogonEvent"/>
        <rdfs:comment xml:lang="en">Inverse of hasLogonType; associates a logon type to events using it.</rdfs:comment>
        <rdfs:label xml:lang="en">isLogonTypeOf</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#isPathOf -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#isPathOf">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#Path"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#LogFile"/>
        <rdfs:comment xml:lang="en">Inverse of hasPath; associates a path to the file it belongs to.</rdfs:comment>
        <rdfs:label xml:lang="en">isPathOf</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#isProcessOf -->

