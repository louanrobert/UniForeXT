        <rdfs:domain rdf:resource="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#Process"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#Process"/>
        <rdfs:comment xml:lang="en">Relates a process to its parent process.</rdfs:comment>
        <rdfs:label xml:lang="en">hasParentProcess</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#hasPath -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#hasPath">
        <rdfs:subPropertyOf rdf:resource="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#relational_property"/>
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#isPathOf"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#Independent_entity"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#Path"/>
        <rdfs:comment xml:lang="en">Relates a file to its file system path.</rdfs:comment>
        <rdfs:label xml:lang="en">hasPath</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#hasProcess -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#hasProcess">
        <rdfs:subPropertyOf rdf:resource="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#relational_property"/>
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#isProcessOf"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#Independent_entity"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#Process"/>
        <rdfs:comment xml:lang="en">Relates an entity to a process associated with it.</rdfs:comment>
        <rdfs:label xml:lang="en">hasProcess</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#hasUser -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#hasUser">
