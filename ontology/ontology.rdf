    <!-- http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#hasAttackTactic -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#hasAttackTactic">
        <rdfs:subPropertyOf rdf:resource="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#relational_property"/>
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#isAttackTacticOf"/>
