        <rdfs:domain rdf:resource="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#Domain_entity"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#Domain_entity"/>
        <rdfs:comment xml:lang="en">Auxiliary super-property for relational links between ontology entities.</rdfs:comment>
