    <!-- http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#Command -->

    <owl:Class rdf:about="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#Command">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#Independent_entity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#hasComputer"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#Computer"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#hasUser"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#User"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#hasDescription"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Command observed in the forensic context.</rdfs:comment>
