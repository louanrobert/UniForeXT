        <rdfs:range rdf:resource="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#AttackTactic"/>
        <rdfs:comment xml:lang="en">Links an element to the ATT&amp;CK tactic it is associated with.</rdfs:comment>
        <rdfs:label xml:lang="en">hasAttackTactic</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#hasAttackTechnique -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#hasAttackTechnique">
