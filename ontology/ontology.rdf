        <owl:inverseOf rdf:resource="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#isCommandOf"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#Independent_entity"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#Command"/>
        <rdfs:comment xml:lang="en">Relates an entity to the command associated with it.</rdfs:comment>
        <rdfs:label xml:lang="en">hasCommand</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#hasComputer -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#hasComputer">
        <rdfs:subPropertyOf rdf:resource="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#relational_property"/>
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#isComputerOf"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#Independent_entity"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#Computer"/>
        <rdfs:comment xml:lang="en">Relates an entity to the computer on which it occurred or was observed.</rdfs:comment>
        <rdfs:label xml:lang="en">hasComputer</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#hasDetection -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#hasDetection">
        <rdfs:subPropertyOf rdf:resource="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#relational_property"/>
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#isDetectionOf"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#Event"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#Detection"/>
        <rdfs:comment xml:lang="en">Links an event to the detection that identified it.</rdfs:comment>
        <rdfs:label xml:lang="en">hasDetection</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#hasFile -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#hasFile">
        <rdfs:subPropertyOf rdf:resource="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#relational_property"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#hasLogFile -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#hasLogFile">
        <rdfs:subPropertyOf rdf:resource="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#relational_property"/>
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#isLogFileOf"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#Independent_entity"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#LogFile"/>
        <rdfs:comment xml:lang="en">Links an entity to the log file used as evidence or source.</rdfs:comment>
        <rdfs:label xml:lang="en">hasLogFile</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#hasLogonEvent -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#hasLogonEvent">
        <rdfs:subPropertyOf rdf:resource="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#relational_property"/>
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#isLogonEventOf"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#Session"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#LogonEvent"/>
        <rdfs:comment xml:lang="en">Associates a session with its logon event.</rdfs:comment>
        <rdfs:label xml:lang="en">hasLogonEvent</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#hasLogonType -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#hasLogonType">
        <rdfs:subPropertyOf rdf:resource="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#relational_property"/>
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#isLogonTypeOf"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#LogonEvent"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#LogonType"/>
        <rdfs:comment xml:lang="en">Specifies the logon type associated with a logon event.</rdfs:comment>
        <rdfs:label xml:lang="en">hasLogonType</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#hasParentProcess -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#hasParentProcess">
        <rdfs:subPropertyOf rdf:resource="http://www.semanticweb.org/robert_louan/ontologies/2026/1/unified-forensics-results#hasProcess"/>
